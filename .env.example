# ── Backend API URL ─────────────────────────────────────────────────────────
# Used by both the browser (lead form) and Next.js server actions (admin panel)
NEXT_PUBLIC_API_URL="http://localhost:5000"

# Server-side only override (optional — falls back to NEXT_PUBLIC_API_URL)
# API_URL="http://api:5000"   # useful inside Docker Compose

# ── Admin credentials ────────────────────────────────────────────────────────
# These are managed in the backend. Set them there via ADMIN_EMAIL / ADMIN_PASSWORD.
# The frontend no longer hard-codes credentials.
